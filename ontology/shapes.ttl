@prefix ro:   <https://w3id.org/ai-samd-governance/regonto#> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

##############################################################
#  SHACL shapes — 규제 온톨로지 데이터 품질 제약 (thesis 5.3.5)
#  온톨로지가 컨트랙트 파라미터의 단일 진실 원천으로 기능하기
#  위한 무결성 규칙: 위반 시 파라미터 도출 파이프라인 차단
##############################################################

### 요구사항: 원칙 실현·관할·법적 근거가 모두 있어야 한다
ro:RequirementShape a sh:NodeShape ;
    sh:targetClass ro:RegulatoryRequirement ;
    sh:property [
        sh:path ro:realizes ; sh:minCount 1 ;
        sh:class ro:RegulatoryPrinciple ;
        sh:message "요구사항은 최소 1개의 규제 원칙을 실현해야 한다"@ko ;
    ] ;
    sh:property [
        sh:path ro:hasJurisdiction ; sh:minCount 1 ;
        sh:class ro:Jurisdiction ;
        sh:message "요구사항은 최소 1개의 관할을 가져야 한다"@ko ;
    ] ;
    sh:property [
        sh:path ro:groundedIn ; sh:minCount 1 ;
        sh:class ro:LegalProvision ;
        sh:message "요구사항은 최소 1개의 법적 근거 조문을 가져야 한다"@ko ;
    ] .

### 기술 구현: 최소 1개 요구사항을 구현해야 한다
ro:ImplementationShape a sh:NodeShape ;
    sh:targetClass ro:TechnicalImplementation ;
    sh:property [
        sh:path ro:implements ; sh:minCount 1 ;
        sh:class ro:RegulatoryRequirement ;
        sh:message "기술 구현은 최소 1개의 요구사항을 구현해야 한다"@ko ;
    ] .

### 검증 메트릭: 최소 1개 구현을 검증해야 한다
ro:MetricShape a sh:NodeShape ;
    sh:targetClass ro:ValidationMetric ;
    sh:property [
        sh:path ro:validates ; sh:minCount 1 ;
        sh:class ro:TechnicalImplementation ;
        sh:message "검증 메트릭은 최소 1개의 기술 구현을 검증해야 한다"@ko ;
    ] .

### 계획 파라미터 세트: 파라미터 도출의 전제 조건
ro:PlanParameterShape a sh:NodeShape ;
    sh:targetClass ro:PlanParameterSet ;
    sh:property [
        sh:path ro:appliesTo ; sh:minCount 1 ; sh:maxCount 1 ;
        sh:class ro:Jurisdiction ;
        sh:message "파라미터 세트는 정확히 1개의 관할에 적용되어야 한다"@ko ;
    ] ;
    sh:property [
        sh:path ro:derivedFromRequirement ; sh:minCount 1 ;
        sh:message "파라미터 세트는 도출 근거 요구사항을 가져야 한다"@ko ;
    ] ;
    sh:property [
        sh:path ro:minAUC ; sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ; sh:maxInclusive 10000 ;
        sh:message "minAUC는 0~10000(x10000 스케일링) 범위의 정수 1개여야 한다"@ko ;
    ] ;
    sh:property [
        sh:path ro:minSensitivity ; sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ; sh:maxInclusive 10000 ;
        sh:message "minSensitivity는 0~10000 범위의 정수 1개여야 한다"@ko ;
    ] ;
    sh:property [
        sh:path ro:minSpecificity ; sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ; sh:maxInclusive 10000 ;
        sh:message "minSpecificity는 0~10000 범위의 정수 1개여야 한다"@ko ;
    ] ;
    sh:property [
        sh:path ro:maxDataChangeRate ; sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 1 ; sh:maxInclusive 10000 ;
        sh:message "maxDataChangeRate는 1~10000(x100 스케일링) 범위의 정수 1개여야 한다"@ko ;
    ] ;
    sh:property [
        sh:path ro:allowedChangeType ; sh:minCount 1 ;
        sh:datatype xsd:integer ;
        sh:in ( 1 2 3 ) ;
        sh:message "허용 변경 유형은 조건부 면제 유형(1~3)만 가능하다 (4~7 중대, 8~9 경미는 계획 대상 아님)"@ko ;
    ] .

### 법적 조문: 참조 문자열 필수
ro:ProvisionShape a sh:NodeShape ;
    sh:targetClass ro:LegalProvision ;
    sh:property [
        sh:path ro:provisionRef ; sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "법적 조문은 정확히 1개의 참조 문자열을 가져야 한다"@ko ;
    ] .
